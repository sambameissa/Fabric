	column ItemName
		lineageTag: 858e66a2-2f99-4848-aced-f389aedac524
		summarizeBy: none
		isNameInferred
		sourceColumn: [ItemName]

		annotation SummarizationSetBy = Automatic

	partition SM_Semantic_Models-0cbb5a1f-1a3c-4c3b-8f5d-7940949ed500 = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    DISTINCT(SM_ExecutionMetrics[ItemId]), 
				    "WorkspaceId", CALCULATE(MAX(SM_ExecutionMetrics[WorkspaceId])), 
				    "ItemURL", CONCATENATE("https://app.fabric.microsoft.com/datahub/datasets/",SM_ExecutionMetrics[ItemId]), 
				    "ItemName", CALCULATE(MAX(SM_ExecutionMetrics[Semantic Model]),KEEPFILTERS(SM_ExecutionMetrics[ItemId]<>SM_ExecutionMetrics[Semantic Model])), 
				    "WorkspaceName", CALCULATE(MAX(SM_ExecutionMetrics[WorkspaceName]))
				    )
				```

	annotation PBI_Id = 67a9d52c7e854cc4a860bd5b45850538

