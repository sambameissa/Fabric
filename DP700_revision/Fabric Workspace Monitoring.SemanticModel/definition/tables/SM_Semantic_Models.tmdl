table SM_Semantic_Models
	lineageTag: dd9e522d-6584-41ec-8e2e-d7aff0a6882a

	measure Item = COUNTROWS('SM_Semantic_Models')
		formatString: 0
		lineageTag: fb03806a-6977-46c8-a9fd-94777580e4fd

	measure Workspaces = DISTINCTCOUNT('SM_Semantic_Models'[WorkspaceId])
		formatString: #,0
		lineageTag: 6899af80-8cfa-4f86-8b63-9b703cfab015

	measure 'Time window start' = INT(NOW() - [Execution From]) & "d ago"
		lineageTag: 20e809fb-490a-4b7d-a405-6a58f4dd3f26

	measure 'Time window end' = IF([Execution To]>NOW(), 0, INT(NOW() - [Execution To])) & "d ago"
		lineageTag: 0019cce8-c15d-48df-8fc6-c6e68f0db5ff

	column WorkspaceId
		lineageTag: 1755b383-416f-41d0-84a4-479d4677f867
		summarizeBy: none
		isNameInferred
		sourceColumn: [WorkspaceId]

		annotation SummarizationSetBy = Automatic

	column WorkspaceName
		lineageTag: 9c5af338-e7f3-4352-a54d-077fc58eca22
		summarizeBy: none
		isNameInferred
		sourceColumn: [WorkspaceName]

		annotation SummarizationSetBy = Automatic

	column ItemId
