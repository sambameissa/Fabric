	partition EH_Queries = m
		mode: import
		queryGroup: Eventhouses
		source = ```
				let
				    KustoParametersDeclareQuery = Text.Combine({"declare query_parameters(", 
				                                 "uri:string = '", #"Query URI","',",
				                                 "dbid:string = '",_ItemId,"',",
				                                 "offset:timespan = timespan(",Number.ToText(#"UTC Offset Hours"),"h),",
				                                 "RangeStartTime:datetime = datetime(", DateTime.ToText((if RangeStart is null then DateTime.From(Date.AddDays(DateTimeZone.UtcNow(),-#"Days Ago To Start")) else RangeStart), "yyyy-MM-dd HH:mm"), "), " , 
				                                 "RangeEndTime:datetime = datetime(", DateTime.ToText((if RangeEnd is null then DateTime.From(Date.AddDays(DateTimeZone.UtcNow(),-#"Days Ago To Finish"+1)) else RangeEnd), "yyyy-MM-dd HH:mm"), ")); " }),
				    ActualQueryWithKustoParameters ="
				set notruncation;
				set ClientRequestIdPrefix='WorkspaceMonitoring';
				EventhouseQueryLogs 
				| where Timestamp >=RangeStartTime-1h and Timestamp <RangeEndTime+15m
				| extend Identity=todynamic(tostring(Identity))
				| extend User=coalesce(Identity.claims.upn, Identity.claims.AppId)
				| extend FailureReason= iff(FailureReason =='[none]', '', FailureReason)
				| extend DashboardId=iif(SourceApplication =='Fabric RTA', substring(CorrelationId,62, 36), '')
				| parse ResultTableStatistics with '[' ResultTableStatistics:dynamic ']'
				| extend RowCount=ResultTableStatistics.RowCount, TableSize=ResultTableStatistics.TableSize
				| extend QueryHash = hash_md5(QueryText)
				| extend Application = case (SourceApplication =='PowerBI', 'PowerBI', SourceApplication == 'Kusto Web Explorer', 'Kusto Web Explorer', SourceApplication == 'Fabric RTA' and CorrelationId startswith 'Kusto.Web.RTA.QuickQuery', 'Quick Query', SourceApplication =='Fabric RTA' and CorrelationId startswith 'Kusto.Web.RTA.QuerySet', 'KQL QuerySet', SourceApplication=='Fabric RTA' and CorrelationId startswith 'Kusto.Web.RTA.Dashboards', 'RT Dashboard', SourceApplication == 'Unknown' and CorrelationId startswith 'KD2RunQuery', 'Data Activator/SDK' , 'Unknown')
				| project Timestamp, ItemKind, ItemId, ItemName, WorkspaceId, WorkspaceName, CapacityId, User, OperationName, OperationId, OperationStartTime, OperationEndTime, SourceApplication, Application, DashboardId, Status, DurationMs, CpuTimeMs, MemoryPeakBytes, DatabaseId, DatabaseName, QueryText, QueryHash, FailureReason
				, CacheHotHitsBytes, CacheHotMissesBytes, CacheColdHitsBytes, CacheColdMissesBytes, ScannedRowsCount, ScannedExtentsCount, ExtentsMaxScannedTime, ExtentsMinScannedTime, ResultTableCount, TotalRowsCount, TotalExtentsCount, RowCount, TableSize
				| where OperationEndTime >=RangeStartTime and OperationEndTime <RangeEndTime
				| extend dimDate=bin(Timestamp,30s)+offset, Timestamp=bin(Timestamp,1s)+offset, OperationStartTime=bin(OperationStartTime,1s)+offset, OperationEndTime=bin(OperationEndTime,1s)+offset, ExtentsMaxScannedTime=bin(ExtentsMaxScannedTime,1s)+offset, ExtentsMinScannedTime=bin(ExtentsMinScannedTime,1s)+offset
				",
				
				    finalQuery = Text.Combine({KustoParametersDeclareQuery, ActualQueryWithKustoParameters}),
				
				    Source = AzureDataExplorer.Contents(#"Query URI", "Monitoring Eventhouse", finalQuery, [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception

